root = true

[*]
charset = utf-8
# LF para alinhar com a política do repositório (.gitattributes: eol=lf).
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Exceção: arquivos .sln são CRLF no repositório (.gitattributes: *.sln eol=crlf).
[*.sln]
end_of_line = crlf

[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets,xml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# ---- Convenções C# ----
[*.cs]
# Usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# Namespaces com escopo de arquivo (C# 10+)
csharp_style_namespace_declarations = file_scoped:warning

# this. desnecessário
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Tipos da linguagem em vez de tipos da BCL (int vs Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# var
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Membros com corpo de expressão
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:silent
csharp_style_expression_bodied_local_functions = when_on_single_line:silent

# Pattern matching e recursos modernos
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_switch_expression = true:suggestion

# Modificadores de acessibilidade explícitos
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:suggestion

# 'readonly' onde possível
dotnet_style_readonly_field = true:warning

# ---- Estilo de código deliberado (IDE*) ----
# O SDK 11 (latest-all) eleva regras de estilo IDE a warning. As preferências abaixo
# refletem o estilo intencional do código — não são supressões de bugs.
# Guard clauses / early-returns de uma linha sem chaves (IDE0011).
csharp_prefer_braces = when_multiline:silent
# Early-return explícito em vez de expressão condicional/ternário em returns (IDE0046).
dotnet_style_prefer_conditional_expression_over_return = false:silent
# Construtores explícitos (com XML docs) em vez de construtor primário nas classes base (IDE0290).
csharp_style_prefer_primary_constructors = false:silent

# ---- Supressões justificadas (escopo: biblioteca principal) ----
# Com AnalysisLevel=latest-all + TreatWarningsAsErrors, algumas regras CA conflitam
# com decisões de design DELIBERADAS e documentadas no PRD §5/§9. Suprimimos só essas,
# mantendo todas as demais ativas.
[src/ReturnSuccessOrError/**.cs]
# Nome do tipo central coincide com o namespace, por design.
dotnet_diagnostic.CA1724.severity = none
# Propriedade 'Error' faz parte do contrato público de parâmetros (PRD §5.4).
dotnet_diagnostic.CA1716.severity = none
# IFeatureService é interface marcadora intencional para a Service Layer (PRD §5.9).
dotnet_diagnostic.CA1040.severity = none
# Exceções são capturadas e convertidas em Failure na fronteira da fonte de dados (PRD §9.5).
dotnet_diagnostic.CA1031.severity = none
# Nullable habilitado: a não-nulidade dos delegates é o contrato; guardas explícitas são redundantes.
dotnet_diagnostic.CA1062.severity = none
# union (C# 15) já fornece igualdade por valor (Equals/GetHashCode gerados pelo compilador);
# operadores ==/!= explícitos não são necessários — compara-se via Equals/pattern matching.
dotnet_diagnostic.CA1815.severity = none
# Conversão implícita é o único idioma de criação da união (return value; / return error;), por
# design; um método nomeado alternativo (ToReturnSuccessOrError) contrariaria a API minimalista.
dotnet_diagnostic.CA2225.severity = none
# 'Populate switch': o switch sobre o union é exaustivo pela linguagem (compilador aceita sem
# default); a regra de estilo ainda não reconhece a exaustividade do union (C# 15 preview).
dotnet_diagnostic.IDE0010.severity = none
dotnet_diagnostic.IDE0072.severity = none
# CS8655: o fluxo de nullability ainda não reconhece a exaustividade do union (C# 15 preview); o
# estado 'default' do struct nunca é produzido — a criação é sempre por conversão implícita.
dotnet_diagnostic.CS8655.severity = none
# Operador de conversão usa corpo de expressão, alinhado ao estilo do projeto (IDE0023).
dotnet_diagnostic.IDE0023.severity = none

# ---- Projeto de testes: relaxar regras inadequadas a código de teste ----
[tests/**.cs]
# Nomes de teste usam underscore (Metodo_Cenario_Resultado) — convenção universal de testes.
dotnet_diagnostic.CA1707.severity = none
# Sugestão de performance irrelevante em arrange de teste.
dotnet_diagnostic.CA1859.severity = none
# Os testes usam tokens próprios (inclusive para verificar propagação) — não o TestContext.
dotnet_diagnostic.xUnit1051.severity = none
# Membros auxiliares de fixtures de teste não precisam ser estáticos.
dotnet_diagnostic.CA1822.severity = none
# Asserts/arrange descartam retornos com frequência — ruído em código de teste.
dotnet_diagnostic.IDE0058.severity = none
# Análise de fluxo do union (C# 15 preview) marca 'is Success/Failure' como sempre-verdadeiro
# (falso positivo) nos helpers de asserção — o pattern matching é exatamente o que valida o caso.
dotnet_diagnostic.CA1508.severity = none
# 'Populate switch' no teste de exaustividade: o switch sobre o union é exaustivo pela linguagem.
dotnet_diagnostic.IDE0072.severity = none

# ---- Projeto de samples: app de demonstração, não código de biblioteca ----
[samples/**.cs]
# App: tipos pedagógicos públicos não precisam ser internal.
dotnet_diagnostic.CA1515.severity = none
# App de console: sem SynchronizationContext problemático, ConfigureAwait é ruído.
dotnet_diagnostic.CA2007.severity = none
# Nullable habilitado: guardas de null explícitas são redundantes.
dotnet_diagnostic.CA1062.severity = none
# Nomes de parâmetro didáticos (p, online, rows) conforme exemplos da spec.
dotnet_diagnostic.CA1725.severity = none
# 'SalesReport' (tipo) coincide com a pasta/namespace da feature — estrutura intencional.
dotnet_diagnostic.CA1724.severity = none
# App de demonstração: descartar retornos (DI fluente, etc.) é idiomático aqui.
dotnet_diagnostic.IDE0058.severity = none
# IDE0005 (usings desnecessários) exige GenerateDocumentationFile; não geramos XML doc no app de demo.
dotnet_diagnostic.IDE0005.severity = none
